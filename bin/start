#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# RAG API — Full Stack Startup Script
# Starts Docker services (PostgreSQL with pgvector), prepares the
# database, and launches the Rails server.
# ============================================================

APP_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$APP_ROOT"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

log()  { echo -e "${GREEN}[start]${NC} $1"; }
warn() { echo -e "${YELLOW}[warn]${NC}  $1"; }
err()  { echo -e "${RED}[error]${NC} $1"; }

# ----------------------------------------------------------
# 1. Check prerequisites
# ----------------------------------------------------------
for cmd in docker ruby bundle; do
  if ! command -v "$cmd" &>/dev/null; then
    err "$cmd is not installed. Please install it first."
    exit 1
  fi
done

if ! docker info &>/dev/null; then
  err "Docker daemon is not running. Please start Docker first."
  exit 1
fi

# ----------------------------------------------------------
# 2. Load environment variables
# ----------------------------------------------------------
if [ -f "$APP_ROOT/.env" ]; then
  log "Loading environment from .env"
  set -a
  # shellcheck disable=SC1091
  source "$APP_ROOT/.env"
  set +a
else
  warn ".env file not found — copying from .env.example"
  if [ -f "$APP_ROOT/.env.example" ]; then
    cp "$APP_ROOT/.env.example" "$APP_ROOT/.env"
    set -a
    source "$APP_ROOT/.env"
    set +a
    warn "Please edit .env and set your GEMINI_API_KEY, then re-run this script."
    exit 1
  else
    err "No .env or .env.example found. Cannot continue."
    exit 1
  fi
fi

# ----------------------------------------------------------
# 3. Start Docker services (PostgreSQL with pgvector)
# ----------------------------------------------------------
log "Starting Docker services (PostgreSQL with pgvector)..."
docker compose up -d

log "Waiting for PostgreSQL to be ready..."
RETRIES=30
until docker exec rag_postgres pg_isready -U "${POSTGRES_USER:-rag_user}" &>/dev/null; do
  RETRIES=$((RETRIES - 1))
  if [ "$RETRIES" -le 0 ]; then
    err "PostgreSQL did not become ready in time."
    exit 1
  fi
  sleep 1
done
log "PostgreSQL is ready."

# ----------------------------------------------------------
# 4. Install Ruby dependencies
# ----------------------------------------------------------
log "Checking Ruby dependencies..."
bundle check &>/dev/null || bundle install

# ----------------------------------------------------------
# 5. Prepare the database
# ----------------------------------------------------------
log "Preparing database..."
bin/rails db:prepare

# ----------------------------------------------------------
# 6. Start the Rails server with Solid Queue
# ----------------------------------------------------------
log "=================================================="
log "  RAG API is starting on http://localhost:3000"
log "  Solid Queue is running inside Puma"
log "=================================================="
# Required on macOS to avoid fork() crash with Objective-C runtime
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES
export SOLID_QUEUE_IN_PUMA=1
exec bin/rails server "$@"
